Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Setup", " ", "Clam", " ", 
    RowBox[{"Geometry", ":", 
     RowBox[{"Dense", " ", "Symmetric", " ", "Seed"}]}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"size", "=", "150"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"hinge", "=", "75"}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Create", " ", "a", " ", "10", "x10", " ", "dense", " ", "random", " ", 
     "cluster", " ", "at", " ", "the", " ", "hinge"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"seedData", "=", 
     RowBox[{"RandomInteger", "[", 
      RowBox[{"1", ",", 
       RowBox[{"{", 
        RowBox[{"10", ",", "10"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"mirroredSeed", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"Reverse", "[", 
        RowBox[{"seedData", ",", "2"}], "]"}], ",", "seedData", ",", "2"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"initialSeed", "=", 
     RowBox[{"CenterArray", "[", 
      RowBox[{"mirroredSeed", ",", 
       RowBox[{"{", 
        RowBox[{"size", ",", "size"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"2.", " ", "Run", " ", 
      RowBox[{"the", "'"}], 
      RowBox[{"Healer", "'"}], " ", "Rule", " ", "224"}], "-", 
     RowBox[{"Increase", " ", "steps", " ", "to", " ", "150"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"rule", "=", 
     RowBox[{"{", 
      RowBox[{"224", ",", 
       RowBox[{"{", 
        RowBox[{"2", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"2", ",", "2", ",", "2"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"2", ",", "1", ",", "2"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"2", ",", "2", ",", "2"}], "}"}]}], "}"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "1"}], "}"}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"clamEvolution", "=", 
     RowBox[{"CellularAutomaton", "[", 
      RowBox[{"rule", ",", "initialSeed", ",", "150"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Visualization", " ", "with", " ", "higher", " ", "contrast"}],
     "*)"}], "\n", 
   RowBox[{"ArrayPlot", "[", 
    RowBox[{
     RowBox[{"Last", "[", "clamEvolution", "]"}], ",", 
     RowBox[{"ColorFunction", "->", "\"\<RustTones\>\""}], ",", 
     RowBox[{"PlotLabel", "->", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<Ruliological Clam Pattern: Recovered Texture\>\"", ",", 
        "14", ",", "Bold"}], "]"}]}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"Mesh", "->", "False"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.982344961388447*^9, 3.982344961390811*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"83303f14-46d2-4f26-b116-5fb57801bf83"],

