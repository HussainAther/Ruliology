Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Define", " ", "the", " ", "Parameters"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"baseRate", "=", "0.08"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tMax", "=", "50"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"noiseLevels", "=", 
     RowBox[{"{", 
      RowBox[{"0.0", ",", "0.005", ",", "0.01", ",", "0.015"}], "}"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "2.", " ", "Define", " ", "the", " ", "Growth", " ", "Function", " ", 
      "with", " ", "sampling"}], "-", 
     RowBox[{"friendly", " ", "noise"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Using", " ", "a", " ", "Module", " ", "ensures", " ", 
     RowBox[{"each", "'"}], 
     RowBox[{"t", "'"}], " ", "gets", " ", "a", " ", "consistent", " ", 
     "noise", " ", "value", " ", "during", " ", "a", " ", "single", " ", 
     "plot", " ", "pass"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"perturbedGrowth", "[", 
      RowBox[{"t_", ",", "\[Sigma]_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "localNoise", "}"}], ",", 
       RowBox[{
        RowBox[{"localNoise", "=", 
         RowBox[{"baseRate", "+", 
          RowBox[{"RandomReal", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", "1"}], "}"}], "*", "\[Sigma]"}], 
           "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"localNoise", "*", "t"}], "]"}], "-", "1"}], "]"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Generate", " ", "individual", " ", "plots", " ", "for", " ", 
     "the", " ", "grid"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"simulations", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"LogPlot", "[", 
        RowBox[{
         RowBox[{"perturbedGrowth", "[", 
          RowBox[{"t", ",", "n"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "0", ",", "tMax"}], "}"}], ",", 
         RowBox[{"PlotRange", "->", 
          RowBox[{"{", 
           RowBox[{"1", ",", 
            RowBox[{"10", "^", "25"}]}], "}"}]}], ",", 
         RowBox[{"PlotStyle", "->", 
          RowBox[{"{", 
           RowBox[{"Thick", ",", 
            RowBox[{
             RowBox[{"ColorData", "[", "\"\<TemperatureMap\>\"", "]"}], "[", 
             RowBox[{"n", "/", 
              RowBox[{"Max", "[", "noiseLevels", "]"}]}], "]"}]}], "}"}]}], ",", 
         RowBox[{"Frame", "->", "True"}], ",", 
         RowBox[{"Axes", "->", "False"}], ",", 
         RowBox[{"FrameLabel", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<Time\>\"", ",", "\"\<Complexity\>\""}], "}"}]}], ",", 
         
         RowBox[{"PlotLabel", "->", 
          RowBox[{"Style", "[", 
           RowBox[{
            RowBox[{"\"\<Noise Level: \>\"", "<>", 
             RowBox[{"ToString", "[", "n", "]"}]}], ",", "12", ",", "Bold"}], 
           "]"}]}], ",", 
         RowBox[{"ImageSize", "->", "350"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "noiseLevels"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Final", " ", "Visualization"}], "*)"}], "\n", 
   RowBox[{"Column", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{"\"\<Sensitivity Analysis: Neural Evolution Robustness\>\"", ",",
         "16", ",", "Bold"}], "]"}], ",", 
      RowBox[{"Spacer", "[", "10", "]"}], ",", 
      RowBox[{"GraphicsGrid", "[", 
       RowBox[{
        RowBox[{"Partition", "[", 
         RowBox[{"simulations", ",", "2"}], "]"}], ",", 
        RowBox[{"ImageSize", "->", "800"}]}], "]"}]}], "}"}], 
    "]"}]}]}]], "Input",
