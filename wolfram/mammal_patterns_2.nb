Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Setup", " ", "Environment"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"size", "=", "150"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"steps", "=", "100"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"injuryStart", "=", "40"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"injuryEnd", "=", "45"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "2.", " ", "Define", " ", "the", " ", "Restoration", " ", "Analysis", " ",
      "Function"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"calculateRestoration", "[", "rule_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"data", ",", "injuredData", ",", "R"}], "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{"Generate", " ", "Baseline", " ", "Pattern"}], "*)"}], 
       RowBox[{
        RowBox[{"data", "=", 
         RowBox[{"CellularAutomaton", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"rule", ",", 
             RowBox[{"{", 
              RowBox[{"2", ",", "1"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"2", ",", "2"}], "}"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"CenterArray", "[", 
              RowBox[{"1", ",", 
               RowBox[{"{", 
                RowBox[{"1", ",", "1"}], "}"}]}], "]"}], ",", "0"}], "}"}], ",",
            "steps"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Generate", " ", "Injured", " ", "Pattern", " ", 
          RowBox[{"(", 
           RowBox[{"Neural", " ", "Scar", " ", "at", " ", "step", " ", "40"}],
            ")"}]}], "*)"}], 
        RowBox[{"injuredData", "=", "data"}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"injuredData", "[", 
          RowBox[{"[", "injuryStart", "]"}], "]"}], "=", 
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"RandomReal", "[", "]"}], "<", "0.3"}], ",", 
              RowBox[{"1", "-", "#"}], ",", "#"}], "]"}], "&"}], ",", 
           RowBox[{"injuredData", "[", 
            RowBox[{"[", "injuryStart", "]"}], "]"}], ",", 
           RowBox[{"{", "2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Evolve", " ", "injured", " ", "state", " ", "through", " ", "the", " ",
           "same", " ", "rule"}], "*)"}], 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"injuredData", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "=", 
           RowBox[{"CellularAutomaton", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"rule", ",", 
               RowBox[{"{", 
                RowBox[{"2", ",", "1"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"2", ",", "2"}], "}"}]}], "}"}], ",", 
             RowBox[{"injuredData", "[", 
              RowBox[{"[", 
               RowBox[{"i", "-", "1"}], "]"}], "]"}]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"injuryStart", "+", "1"}], ",", "steps"}], "}"}]}], "]"}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Calculate", " ", 
          RowBox[{"R", ":", 
           RowBox[{"1", "-", 
            RowBox[{"(", 
             RowBox[{"Normalized", " ", "Difference"}], ")"}]}]}]}], "*)"}], 
        RowBox[{"R", "=", 
         RowBox[{"1", "-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Total", "[", 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{
                RowBox[{"data", "[", 
                 RowBox[{"[", "steps", "]"}], "]"}], "-", 
                RowBox[{"injuredData", "[", 
                 RowBox[{"[", "steps", "]"}], "]"}]}], "]"}], ",", "2"}], 
             "]"}], "/", 
            RowBox[{"Total", "[", 
             RowBox[{
              RowBox[{"data", "[", 
               RowBox[{"[", "steps", "]"}], "]"}], ",", "2"}], "]"}]}], 
           ")"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Max", "[", 
           RowBox[{"0", ",", "R"}], "]"}], ",", 
          RowBox[{"ArrayPlot", "[", 
           RowBox[{
            RowBox[{"data", "[", 
             RowBox[{"[", "steps", "]"}], "]"}], ",", 
            RowBox[{"ColorRules", "->", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"0", "->", "White"}], ",", 
               RowBox[{"1", "->", "Gray"}]}], "}"}]}]}], "]"}]}], "}"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Test", " ", "a", " ", "\"\<Zoo\>\"", " ", "of", " ", 
     "Specific", " ", "Interesting", " ", "Rules"}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "We", " ", "use", " ", "specific", " ", "indices", " ", "that", " ", 
     "often", " ", "yield", " ", "biological", " ", "textures"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ruleIndices", "=", 
     RowBox[{"{", 
      RowBox[{
      "224", ",", "512", ",", "1024", ",", "2048", ",", "4096", ",", "8192", ",",
        "16384", ",", "32768"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"calculateRestoration", "/@", "ruleIndices"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Display", " ", "the", " ", "Catalogue"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Grid", "[", 
    RowBox[{
     RowBox[{"Prepend", "[", 
      RowBox[{"results", ",", 
       RowBox[{"{", 
        RowBox[{"\"\<Restoration (R)\>\"", ",", "\"\<Pattern Archetype\>\""}],
         "}"}]}], "]"}], ",", 
     RowBox[{"Frame", "->", "All"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.98253010172193*^9, 3.9825301017244797`*^9}},
 CellLabel->"In[67]:=",ExpressionUUID->"3a717ec4-c40c-4e76-bcb2-3f33cba8f765"],

