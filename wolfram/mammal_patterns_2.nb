Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "1.", " ", "Setup", " ", "Clam", " ", "and", " ", "Initial", " ", 
    "Growth"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"size", "=", "150"}], ";", 
    RowBox[{"hingeIndex", "=", "75"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"seedData", "=", 
     RowBox[{"RandomInteger", "[", 
      RowBox[{"1", ",", 
       RowBox[{"{", 
        RowBox[{"10", ",", "10"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"mirroredSeed", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"Reverse", "[", 
        RowBox[{"seedData", ",", "2"}], "]"}], ",", "seedData", ",", "2"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"initialSeed", "=", 
     RowBox[{"CenterArray", "[", 
      RowBox[{"mirroredSeed", ",", 
       RowBox[{"{", 
        RowBox[{"size", ",", "size"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"rule", "=", 
     RowBox[{"{", 
      RowBox[{"224", ",", 
       RowBox[{"{", 
        RowBox[{"2", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"2", ",", "2", ",", "2"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"2", ",", "1", ",", "2"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"2", ",", "2", ",", "2"}], "}"}]}], "}"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "1"}], "}"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "2.", " ", "Evolve", " ", "with", " ", "an", " ", "ASYMMETRIC", " ", 
     "injury", " ", "at", " ", "Step", " ", "20"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"evolution", "=", 
     RowBox[{"{", "initialSeed", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"next", "=", 
        RowBox[{"Last", "[", 
         RowBox[{"CellularAutomaton", "[", 
          RowBox[{"rule", ",", 
           RowBox[{"Last", "[", "evolution", "]"}], ",", "1"}], "]"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"t", "==", "20"}], ",", 
         RowBox[{"(*", 
          RowBox[{"Injure", " ", "only", " ", "the", " ", "Left", " ", 
           RowBox[{"Valve", ":", 
            RowBox[{"1", " ", "to", " ", "hingeIndex"}]}]}], "*)"}], 
         RowBox[{
          RowBox[{"next", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"70", ";;", "90"}], ",", 
             RowBox[{"30", ";;", "50"}]}], "]"}], "]"}], "=", 
          RowBox[{"RandomInteger", "[", 
           RowBox[{"1", ",", 
            RowBox[{"{", 
             RowBox[{"21", ",", "21"}], "}"}]}], "]"}]}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"evolution", ",", "next"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "1", ",", "150"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"3.", " ", "Calculate", " ", "Asymmetry", " ", 
     RowBox[{"(", 
      RowBox[{"Hamming", " ", "Distance"}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"leftValves", "=", 
     RowBox[{"evolution", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", 
        RowBox[{"1", ";;", "size"}], ",", 
        RowBox[{"1", ";;", "hingeIndex"}]}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"rightValves", "=", 
     RowBox[{"Map", "[", 
      RowBox[{"Reverse", ",", 
       RowBox[{"evolution", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{"1", ";;", "size"}], ",", 
          RowBox[{
           RowBox[{"hingeIndex", "+", "1"}], ";;", "size"}]}], "]"}], "]"}], ",", 
       RowBox[{"{", "2", "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"asymmetryValues", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Total", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{"BitXor", "[", 
           RowBox[{
            RowBox[{"leftValves", "[", 
             RowBox[{"[", "t", "]"}], "]"}], ",", 
            RowBox[{"rightValves", "[", 
             RowBox[{"[", "t", "]"}], "]"}]}], "]"}], "]"}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"size", "*", "hingeIndex"}], "//", "N"}], ")"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "1", ",", 
         RowBox[{"Length", "[", "evolution", "]"}]}], "}"}]}], "]"}]}], ";"}],
    "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Final", " ", "Plot"}], "*)"}], "\[IndentingNewLine]", 
   
   RowBox[{"ListLinePlot", "[", 
    RowBox[{"asymmetryValues", ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{"Thick", ",", "Red"}], "}"}]}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Evolutionary Steps\>\"", 
        ",", "\"\<Asymmetry Coefficient\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<Bilateral Symmetry Restoration (Rule 224)\>\"", ",", "14",
         ",", "Bold"}], "]"}]}], ",", 
     RowBox[{"Filling", "->", "Bottom"}], ",", 
     RowBox[{"FillingStyle", "->", "LightRed"}], ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{"All", ",", "All"}], "}"}]}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9823467382311077`*^9, 3.982346738233571*^9}, 
   3.982347413421358*^9},
 CellLabel->"In[9]:=",ExpressionUUID->"62572467-9397-4ca5-ae4f-62c11dd36211"],

