      RowBox[{"{", 
       RowBox[{"size", ",", "size"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rule", "=", 
