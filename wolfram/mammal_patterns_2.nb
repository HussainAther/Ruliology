 RowBox[{
  RowBox[{"mirroredSeed", "=", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"Reverse", "[", 
      RowBox[{"seedData", ",", "2"}], "]"}], ",", "seedData", ",", "2"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"initialSeed", "=", 
    RowBox[{"CenterArray", "[", 
