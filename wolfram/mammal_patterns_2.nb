Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Test", " ", "R"}], "-", 
    RowBox[{
    "score", " ", "against", " ", "increasing", " ", "injury", " ", 
     "sizes"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"injurySizes", "=", 
     RowBox[{"Range", "[", 
      RowBox[{"5", ",", "45", ",", "5"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"rScores", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"(*", 
       RowBox[{"(", 
        RowBox[{
        "Insert", " ", "your", " ", "rScore", " ", "calculation", " ", 
         "logic", " ", "here", " ", "inside", " ", "a", " ", "loop"}], ")"}], 
       "*)"}], 
      RowBox[{
       RowBox[{"1.0", "-", 
        RowBox[{"(", 
         RowBox[{"RandomReal", "[", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0.05"}], "}"}], "]"}], ")"}]}], ",", 
       RowBox[{"(*", 
        RowBox[{
        "Placeholder", " ", "for", " ", "actual", " ", "loop", " ", 
         "output"}], "*)"}], 
       RowBox[{"{", 
        RowBox[{"s", ",", "injurySizes"}], "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"injurySizes", ",", "rScores"}], "}"}], "]"}], ",", 
     RowBox[{"Mesh", "->", "All"}], ",", 
