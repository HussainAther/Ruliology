      RowBox[{"1.", " ", "Setup", " ", "Clam", " ", "Geometry"}], "===", "===",
       "===", "===", "===", "===", "===", "==="}], "="}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"size", "=", "150"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
