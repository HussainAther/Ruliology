Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Function", " ", "to", " ", "calculate", " ", "the", " ", "percentage", " ",
     "of", " ", "recovery"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"MeasureRecovery", "[", 
      RowBox[{"rule_", ",", "injuryWidth_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"steps", "=", "150"}], ",", 
         RowBox[{"mixAt", "=", "50"}], ",", "init", ",", "clean", ",", 
         "injured", ",", "diff"}], "}"}], ",", 
       RowBox[{
        RowBox[{"init", "=", 
         RowBox[{"CenterArray", "[", 
          RowBox[{
           RowBox[{"{", "1", "}"}], ",", "301"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"clean", "=", 
         RowBox[{"CellularAutomaton", "[", 
          RowBox[{"rule", ",", "init", ",", "steps"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Generate", " ", "injured", " ", "state"}], "*)"}], 
        RowBox[{"injured", "=", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"pre", ",", "mid", ",", "post"}], "}"}], ",", 
           RowBox[{
            RowBox[{"pre", "=", 
             RowBox[{"Take", "[", 
              RowBox[{"clean", ",", "mixAt"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"mid", "=", 
             RowBox[{"Last", "[", "pre", "]"}]}], ";", "\[IndentingNewLine]", 
            
            RowBox[{"(*", 
             RowBox[{
             "Randomly", " ", "perturb", " ", "a", " ", "section", " ", "of", 
              " ", 
              RowBox[{"width", "'"}], 
              RowBox[{"injuryWidth", "'"}]}], "*)"}], 
            RowBox[{
             RowBox[{"mid", "[", 
              RowBox[{"[", 
               RowBox[{
                RowBox[{"151", "-", "injuryWidth"}], ";;", 
                RowBox[{"151", "+", "injuryWidth"}]}], "]"}], "]"}], "=", 
             RowBox[{"RandomInteger", "[", 
              RowBox[{"1", ",", 
               RowBox[{
                RowBox[{"2", "*", "injuryWidth"}], "+", "1"}]}], "]"}]}], ";",
             "\[IndentingNewLine]", 
            RowBox[{"post", "=", 
             RowBox[{"CellularAutomaton", "[", 
              RowBox[{"rule", ",", "mid", ",", 
               RowBox[{"steps", "-", "mixAt"}]}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"Join", "[", 
             RowBox[{"pre", ",", "post"}], "]"}]}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Calculate", " ", "XOR", " ", "Difference"}], "*)"}], 
        RowBox[{"diff", "=", 
         RowBox[{"MapThread", "[", 
          RowBox[{"BitXor", ",", 
           RowBox[{"{", 
            RowBox[{"clean", ",", "injured"}], "}"}], ",", "2"}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{
           RowBox[{"Final", " ", "row", " ", 
            RowBox[{"difference", ":", "1.0"}]}], "=", 
           RowBox[{"Perfect", " ", "recovery"}]}], ",", 
          RowBox[{"0.0", "=", 
           RowBox[{"Total", " ", "divergence"}]}]}], "*)"}], 
        RowBox[{"1.0", "-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Total", "[", 
            RowBox[{"Last", "[", "diff", "]"}], "]"}], "/", 
           RowBox[{"Length", "[", 
            RowBox[{"Last", "[", "diff", "]"}], "]"}]}], ")"}]}]}]}], "]"}]}],
     ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Run", " ", "for", " ", "Rule", " ", "110", " ", "across", " ", "widths", 
     " ", "1", " ", "to", " ", "50"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"w", ",", 
         RowBox[{"Mean", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"MeasureRecovery", "[", 
             RowBox[{"110", ",", "w"}], "]"}], ",", 
            RowBox[{"{", "10", "}"}]}], "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"w", ",", "1", ",", "50", ",", "2"}], "}"}]}], "]"}]}], ";"}],
    "\n", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{"data", ",", 
     RowBox[{"PlotTheme", "->", "\"\<Scientific\>\""}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Injury Width (Cells)\>\"", 
        ",", "\"\<Restoration Score\>\""}], "}"}]}], ",", 
     RowBox[{
     "PlotLabel", 
      "->", "\"\<Rule 110: Resilience as a Function of Injury Scale\>\""}], ",", 
     RowBox[{"Filling", "->", "Bottom"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.977837340230768*^9, 3.9778373402331667`*^9}},
 CellLabel->
  "In[107]:=",ExpressionUUID->"b6876a73-60be-4bfd-a618-d2ce386b3c43"],

