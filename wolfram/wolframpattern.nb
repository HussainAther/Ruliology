 RowBox[{
  RowBox[{
   RowBox[{"perturbWidth", "=", "20"}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"2.", " ", "Initial", " ", "evolution", " ", 
    RowBox[{"(", 
     RowBox[{"Common", " ", "to", " ", "both"}], ")"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"init", "=", 
   RowBox[{"CenterArray", "[", 
    RowBox[{
     RowBox[{"{", "1", "}"}], ",", "201"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"evolution1", "=", 
   RowBox[{"CellularAutomaton", "[", 
    RowBox[{"rule", ",", "init", ",", "steps1"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"latestState", "=", 
    RowBox[{"Last", "[", "evolution1", "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"3.", " ", 
    RowBox[{"Branching", ":", 
     RowBox[{"Control", " ", "vs", " ", "Perturbed"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Control", ":", 
    RowBox[{"No", " ", "changes"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"controlEvolution2", "=", 
    RowBox[{"CellularAutomaton", "[", 
     RowBox[{"rule", ",", "latestState", ",", "steps2"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Perturbed", ":", 
    RowBox[{"Mix", " ", "up", " ", "the", " ", "central", " ", "cells"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mid", "=", 
   RowBox[{"IntegerPart", "[", 
    RowBox[{
     RowBox[{"Length", "[", "latestState", "]"}], "/", "2"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"perturbedState", "=", "latestState"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"perturbedState", "[", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"mid", "-", "perturbWidth"}], ";;", 
      RowBox[{"mid", "+", "perturbWidth"}]}], "]"}], "]"}], "=", 
   RowBox[{"RandomInteger", "[", 
    RowBox[{"1", ",", 
     RowBox[{
      RowBox[{"2", "*", "perturbWidth"}], "+", "1"}]}], "]"}]}], ";"}], "\n", 

 RowBox[{
  RowBox[{
   RowBox[{"experimentEvolution2", "=", 
    RowBox[{"CellularAutomaton", "[", 
     RowBox[{"rule", ",", "perturbedState", ",", "steps2"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"4.", " ", "Visualization"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"controlPlot", "=", 
    RowBox[{"ArrayPlot", "[", 
     RowBox[{
      RowBox[{"Join", "[", 
