Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Ruliological", " ", "Sweep", " ", "of", " ", "All", " ", "256", " ", 
    "Rules"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"stepsBefore", "=", "100"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"stepsAfter", "=", "50"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"width", "=", "201"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "init", ",", "clean", ",", "mixed", ",", "diff", ",", "midRow", ",", 
           RowBox[{"perturbWidth", "=", "10"}]}], "}"}], ",", 
         RowBox[{
          RowBox[{"init", "=", 
           RowBox[{"CenterArray", "[", 
            RowBox[{
             RowBox[{"{", "1", "}"}], ",", "width"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"1.", " ", 
            RowBox[{"The", "'"}], 
            RowBox[{"Clean", "'"}], " ", "Path"}], "*)"}], 
          RowBox[{"clean", "=", 
           RowBox[{"CellularAutomaton", "[", 
            RowBox[{"rule", ",", "init", ",", 
             RowBox[{"stepsBefore", "+", "stepsAfter"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"2.", " ", 
            RowBox[{"The", "'"}], 
            RowBox[{"Mixed", "'"}], " ", "Path", " ", 
            RowBox[{"(", 
             RowBox[{"Interrupt", " ", "at", " ", "Row", " ", "100"}], 
             ")"}]}], "*)"}], 
          RowBox[{"midState", "=", 
           RowBox[{"clean", "\[LeftDoubleBracket]", 
            RowBox[{"stepsBefore", "+", "1"}], "\[RightDoubleBracket]"}]}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Randomize", " ", "a", " ", "section", " ", "of", " ", "the", " ", 
            "row"}], "*)"}], 
          RowBox[{"perturbedState", "=", 
           RowBox[{"ReplacePart", "[", 
            RowBox[{"midState", ",", 
             RowBox[{"Thread", "[", 
              RowBox[{
               RowBox[{"Range", "[", 
                RowBox[{
                 RowBox[{"101", "-", "perturbWidth"}], ",", 
                 RowBox[{"101", "+", "perturbWidth"}]}], "]"}], "\[Rule]", 
               RowBox[{"RandomInteger", "[", 
                RowBox[{"1", ",", 
                 RowBox[{
                  RowBox[{"2", " ", "perturbWidth"}], "+", "1"}]}], "]"}]}], 
              "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"mixed", "=", 
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"Take", "[", 
              RowBox[{"clean", ",", "stepsBefore"}], "]"}], ",", 
             RowBox[{"CellularAutomaton", "[", 
              RowBox[{"rule", ",", "perturbedState", ",", "stepsAfter"}], 
              "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"3.", " ", "The", " ", "Difference", " ", "Map", " ", 
            RowBox[{"(", "XOR", ")"}]}], "*)"}], 
          RowBox[{"diff", "=", 
           RowBox[{"MapThread", "[", 
            RowBox[{"BitXor", ",", 
             RowBox[{"{", 
              RowBox[{"clean", ",", "mixed"}], "}"}], ",", "2"}], "]"}]}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Return", " ", "a", " ", "small", " ", "plot", " ", "for", " ", 
            "each", " ", "rule"}], "*)"}], 
          RowBox[{"ArrayPlot", "[", 
           RowBox[{"diff", ",", 
            RowBox[{"ColorRules", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"1", "\[Rule]", "Red"}], ",", 
               RowBox[{"0", "\[Rule]", "White"}]}], "}"}]}], ",", 
            RowBox[{"Frame", "\[Rule]", "False"}], ",", 
            RowBox[{"PlotLabel", "\[Rule]", 
             RowBox[{"Style", "[", 
              RowBox[{"rule", ",", "8"}], "]"}]}]}], "]"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"rule", ",", "0", ",", "255"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"Display", " ", "as", " ", "a", " ", "16", "x16", " ", "grid"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"GraphicsGrid", "[", 
    RowBox[{
     RowBox[{"Partition", "[", 
      RowBox[{"results", ",", "16"}], "]"}], ",", 
     RowBox[{"ImageSize", "\[Rule]", "1000"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.977905735518611*^9, 3.97790573552304*^9}},
 CellLabel->
  "In[160]:=",ExpressionUUID->"7f452b0a-f643-4fae-a122-eedc60ce11ff"],

