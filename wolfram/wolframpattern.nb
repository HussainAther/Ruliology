      RowBox[{"ColorRules", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"0", "->", "White"}], ",", 
         RowBox[{"1", "->", "Black"}]}], "}"}]}], ",", 
      RowBox[{"PlotLabel", "->", "\"\<Control (No Injury)\>\""}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"experimentPlot", "=", 
    RowBox[{"ArrayPlot", "[", 
     RowBox[{
      RowBox[{"Join", "[", 
       RowBox[{"evolution1", ",", "experimentEvolution2"}], "]"}], ",", 
      RowBox[{"ColorRules", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"0", "->", "White"}], ",", 
         RowBox[{"1", "->", "Black"}]}], "}"}]}], ",", 
      RowBox[{"Epilog", "->", 
