Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Setup", " ", "Parameters"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"rule", "=", "30"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"The", " ", "rule", " ", "under", " ", 
     RowBox[{"study", "[", 
      RowBox[{
       RowBox[{"cite", ":", "1"}], ",", "5", ",", "207"}], "]"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"steps1", "=", "50"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "evolution", " ", 
     RowBox[{"time", "[", 
      RowBox[{
       RowBox[{"cite", ":", "3"}], ",", "6", ",", "210"}], "]"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"steps2", "=", "100"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Time", " ", "after", " ", 
     RowBox[{"mixing", "[", 
      RowBox[{
       RowBox[{"cite", ":", "4"}], ",", "6", ",", "211"}], "]"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"perturbWidth", "=", "20"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Width", " ", "of", " ", 
     RowBox[{"the", "'"}], 
     RowBox[{"mixed", "'"}], " ", 
     RowBox[{"region", "[", 
      RowBox[{
       RowBox[{"cite", ":", "6"}], ",", "212"}], "]"}]}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"2.", " ", "Initial", " ", "Evolution"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"init", "=", 
      RowBox[{"CenterArray", "[", 
       RowBox[{
        RowBox[{"{", "1", "}"}], ",", "201"}], "]"}]}], ";"}], "[", 
    RowBox[{
     RowBox[{"cite", ":", "8"}], ",", "214"}], "]"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"evolution1", "=", 
      RowBox[{"CellularAutomaton", "[", 
       RowBox[{"rule", ",", "init", ",", "steps1"}], "]"}]}], ";"}], "[", 
    RowBox[{
     RowBox[{"cite", ":", "9"}], ",", "215"}], "]"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"latestState", "=", 
      RowBox[{"Last", "[", "evolution1", "]"}]}], ";"}], "[", 
    RowBox[{
     RowBox[{"cite", ":", "10"}], ",", "216"}], "]"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"3.", " ", 
     RowBox[{"Mixing", "/", "Perturbation"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"mid", "=", 
      RowBox[{"IntegerPart", "[", 
       RowBox[{
        RowBox[{"Length", "[", "latestState", "]"}], "/", "2"}], "]"}]}], 
     ";"}], "[", 
    RowBox[{
     RowBox[{"cite", ":", "13"}], ",", "218"}], "]"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"perturbedState", "=", "latestState"}], ";"}], "[", 
    RowBox[{
     RowBox[{"cite", ":", "14"}], ",", "219"}], "]"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"Corrected", " ", "syntax", " ", "for", " ", "part", " ", 
     RowBox[{"assignment", "[", 
      RowBox[{"cite", ":", "220"}], "]"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"perturbedState", "\[LeftDoubleBracket]", 
       RowBox[{
        RowBox[{"mid", "-", "perturbWidth"}], ";;", 
        RowBox[{"mid", "+", "perturbWidth"}]}], "\[RightDoubleBracket]"}], "=", 
      RowBox[{"RandomInteger", "[", 
       RowBox[{"1", ",", 
        RowBox[{
         RowBox[{"2", "*", "perturbWidth"}], "+", "1"}]}], "]"}]}], ";"}], "[", 
    RowBox[{
     RowBox[{"cite", ":", "15"}], ",", "221"}], "]"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Recovery", " ", "Evolution"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"evolution2", "=", 
      RowBox[{"CellularAutomaton", "[", 
       RowBox[{"rule", ",", "perturbedState", ",", "steps2"}], "]"}]}], ";"}],
     "[", 
    RowBox[{
     RowBox[{"cite", ":", "17"}], ",", "223"}], "]"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"5.", " ", "Visualization"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ArrayPlot", "[", 
     RowBox[{
      RowBox[{"Join", "[", 
       RowBox[{"evolution1", ",", "evolution2"}], "]"}], ",", 
      RowBox[{"Mesh", "\[Rule]", "True"}], ",", 
      RowBox[{"ColorRules", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"0", "\[Rule]", "White"}], ",", 
         RowBox[{"1", "\[Rule]", "Black"}]}], "}"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"[", 
         RowBox[{
          RowBox[{"cite", ":", "19"}], ",", "20", ",", "225", ",", "226"}], 
         "]"}], " ", "Epilog"}], "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"Red", ",", 
         RowBox[{"Thickness", "[", "0.005", "]"}], ",", 
         RowBox[{"Line", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "steps1"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"201", ",", "steps1"}], "}"}]}], "}"}], "]"}]}], "}"}]}],
       ",", 
      RowBox[{"(*", 
       RowBox[{
       "Fixed", " ", "coordinate", " ", "to", " ", "the", " ", "mixing", " ", 
        
        RowBox[{"point", "[", 
         RowBox[{"cite", ":", "226"}], "]"}]}], "*)"}], 
      RowBox[{
      "PlotLabel", 
       "\[Rule]", "\"\<Pattern Restoration Experiment (Red Line = Mixing \
Point)\>\""}]}], "]"}], "[", 
    RowBox[{
     RowBox[{"cite", ":", "21"}], ",", "227"}], "]"}]}]}]], "Input",
