Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"(*", "Parameters", "*)"}], 
    RowBox[{
     RowBox[{
      RowBox[{"rule", "=", "110"}], ";", 
      RowBox[{"steps", "=", "200"}], ";", 
      RowBox[{"gridSizes", "=", 
       RowBox[{"{", 
        RowBox[{"50", ",", "100", ",", "200", ",", "500"}], "}"}]}], ";", 
      RowBox[{"injuryWidth", "=", "10"}], ";", 
      RowBox[{"injuryTime", "=", "50"}], ";"}], "\[IndentingNewLine]", "\n", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "Function", " ", "to", " ", "calculate", " ", "restoration", " ", 
          "for", " ", "a", " ", "specific", " ", "size"}], ")"}], " ", 
        RowBox[{"testSize", "[", "L_", "]"}]}], ":=", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"control", ",", "injury", ",", "diff"}], "}"}], ",", 
         RowBox[{"(", 
          RowBox[{"Control", " ", "Evolution"}]}]}]}]}], "*)"}], 
     RowBox[{
      RowBox[{"control", "=", 
       RowBox[{"CellularAutomaton", "[", 
        RowBox[{"rule", ",", 
         RowBox[{"CenterArray", "[", 
          RowBox[{"1", ",", "L"}], "]"}], ",", "steps"}], "]"}]}], ";"}], 
     "\[IndentingNewLine]", "\n", 
     RowBox[{"(*", 
      RowBox[{"Create", " ", "Injury", " ", "at", " ", "injuryTime"}], "*)"}], 
     RowBox[{
      RowBox[{"injuredState", "=", 
       RowBox[{"control", "[", 
        RowBox[{"[", 
         RowBox[{"injuryTime", "+", "1"}], "]"}], "]"}]}], ";", 
      RowBox[{"mid", "=", 
       RowBox[{"Floor", "[", 
        RowBox[{"L", "/", "2"}], "]"}]}], ";", 
      RowBox[{
       RowBox[{"injuredState", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"mid", "-", 
           RowBox[{"Floor", "[", 
            RowBox[{"injuryWidth", "/", "2"}], "]"}]}], ";;", 
          RowBox[{"mid", "+", 
           RowBox[{"Floor", "[", 
            RowBox[{"injuryWidth", "/", "2"}], "]"}]}]}], "]"}], "]"}], "=", 
       RowBox[{"RandomInteger", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "1"}], "}"}], ",", 
         RowBox[{"injuryWidth", "+", "1"}]}], "]"}]}], ";"}], 
     "\[IndentingNewLine]", "\n", 
     RowBox[{"(*", 
      RowBox[{"Evolve", " ", "Injury"}], "*)"}], 
     RowBox[{
      RowBox[{"injury", "=", 
       RowBox[{"CellularAutomaton", "[", 
        RowBox[{"rule", ",", "injuredState", ",", 
         RowBox[{"steps", "-", "injuryTime"}]}], "]"}]}], ";"}], 
     "\[IndentingNewLine]", "\n", 
     RowBox[{"(*", 
      RowBox[{
      "Compare", " ", "only", " ", "the", " ", "steps", " ", "after", " ", 
       "injury"}], "*)"}], 
     RowBox[{
      RowBox[{"diff", "=", 
       RowBox[{"Total", "[", 
        RowBox[{
         RowBox[{"BitXor", "[", 
          RowBox[{
           RowBox[{"control", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"injuryTime", "+", "1"}], ";;"}], "]"}], "]"}], ",", 
           "injury"}], "]"}], ",", "2"}], "]"}]}], ";"}], 
     "\[IndentingNewLine]", "\n", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Return", " ", "1", " ", "if", " ", "healed", " ", 
        RowBox[{"(", 
         RowBox[{"diff", " ", "is", " ", "0"}], ")"}]}], ",", 
       RowBox[{"0", " ", "otherwise"}]}], "*)"}], 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"diff", "==", "0"}], ",", "1", ",", "0"}], "]"}]}], "]"}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Run", " ", "the", " ", "loop", " ", "and", " ", "print", " ", "results"}],
    "*)"}], 
  RowBox[{
   RowBox[{"results", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"s", ",", 
        RowBox[{"testSize", "[", "s", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"s", ",", "gridSizes"}], "}"}]}], "]"}]}], ";", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Grid Size vs Healing Success (1=Healed, 0=Failed): \>\"", ",",
      "results"}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.978018879524289*^9, 3.978018879527438*^9}},
 CellLabel->
  "In[181]:=",ExpressionUUID->"5b5ae31f-5e62-4021-b329-55eed69087c3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "Parameters", "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"stepsBefore", "=", "100"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"stepsAfter", "=", "50"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"width", "=", "201"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"perturbWidth", "=", "10"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Function", " ", "to", " ", "generate", " ", "a", " ", "single", " ", 
     "rule", " ", "plot"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"generateRulePlot", "[", "rule_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "init", ",", "clean", ",", "midState", ",", "perturbedState", ",", 
         "mixed", ",", "diff"}], "}"}], ",", 
       RowBox[{
        RowBox[{"init", "=", 
         RowBox[{"CenterArray", "[", 
          RowBox[{
           RowBox[{"{", "1", "}"}], ",", "width"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"clean", "=", 
         RowBox[{"CellularAutomaton", "[", 
          RowBox[{"rule", ",", "init", ",", 
           RowBox[{"stepsBefore", "+", "stepsAfter"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"midState", "=", 
         RowBox[{"clean", "[", 
          RowBox[{"[", 
           RowBox[{"stepsBefore", "+", "1"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"perturbedState", "=", 
         RowBox[{"ReplacePart", "[", 
          RowBox[{"midState", ",", 
           RowBox[{"Thread", "[", 
            RowBox[{
             RowBox[{"Range", "[", 
              RowBox[{
               RowBox[{"101", "-", "perturbWidth"}], ",", 
               RowBox[{"101", "+", "perturbWidth"}]}], "]"}], "->", 
             RowBox[{"RandomInteger", "[", 
              RowBox[{"1", ",", 
               RowBox[{
                RowBox[{"2", " ", "perturbWidth"}], "+", "1"}]}], "]"}]}], 
            "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"mixed", "=", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"Take", "[", 
            RowBox[{"clean", ",", "stepsBefore"}], "]"}], ",", 
           RowBox[{"CellularAutomaton", "[", 
            RowBox[{"rule", ",", "perturbedState", ",", "stepsAfter"}], 
            "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"diff", "=", 
         RowBox[{"MapThread", "[", 
          RowBox[{"BitXor", ",", 
           RowBox[{"{", 
            RowBox[{"clean", ",", "mixed"}], "}"}], ",", "2"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ArrayPlot", "[", 
         RowBox[{"diff", ",", 
          RowBox[{"ColorRules", "->", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"1", "->", "Red"}], ",", 
             RowBox[{"0", "->", "White"}]}], "}"}]}], ",", 
          RowBox[{"Frame", "->", "True"}], ",", 
          RowBox[{"FrameTicks", "->", "None"}], ",", 
          RowBox[{"PlotLabel", "->", 
           RowBox[{"Style", "[", 
            RowBox[{
             RowBox[{"\"\<Rule \>\"", "<>", 
              RowBox[{"ToString", "[", "rule", "]"}]}], ",", "10"}], 
            "]"}]}]}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Generate", " ", "all", " ", "256", " ", "plots"}], "*)"}], "\n", 
   
   RowBox[{
    RowBox[{"allPlots", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"generateRulePlot", "[", "r", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "0", ",", "255"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Partition", " ", "into", " ", "16", " ", "groups", " ", 
     RowBox[{"(", 
      RowBox[{"16", " ", "rules", " ", "each"}], ")"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"figureGroups", "=", 
     RowBox[{"Partition", "[", 
      RowBox[{"allPlots", ",", "16"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Display", " ", "the", " ", "first", " ", "group", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Rules", " ", "0"}], "-", "15"}], ")"}], " ", "as", " ", "an", 
     " ", "example"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"To", " ", "export", " ", "all", " ", "16"}], ",", 
     RowBox[{
     "you", " ", "would", " ", "loop", " ", "this", " ", "or", " ", "use", " ", 
      RowBox[{"Export", "[", "]"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"GraphicsGrid", "[", 
    RowBox[{
     RowBox[{"Partition", "[", 
      RowBox[{
       RowBox[{"figureGroups", "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", "4"}], "]"}], ",", 
     RowBox[{"ImageSize", "->", "800"}], ",", 
     RowBox[{"Spacings", "->", "10"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9780939312536182`*^9, 3.978093931257534*^9}},
 CellLabel->
  "In[181]:=",ExpressionUUID->"e58eae33-0bdd-4174-8626-5a68a8f4c12e"],

