              RowBox[{"steps2", "+", "steps1", "-", "steps1"}]}], "}"}]}], 
           "}"}], "]"}]}], "}"}]}], ",", 
      RowBox[{"PlotLabel", "->", "\"\<Experiment (With Injury)\>\""}]}], 
