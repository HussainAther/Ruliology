Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Setup", " ", "Parameters"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"rule", "=", "30"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"The", " ", "rule", " ", "we", " ", "are", " ", "studying"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"steps1", "=", "50"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "evolution", " ", "time"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"steps2", "=", "100"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Time", " ", "after", " ", "mixing"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"perturbWidth", "=", "20"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"How", " ", "many", " ", "cells", " ", 
     RowBox[{"to", "'"}], "mix", " ", 
     RowBox[{"up", "'"}]}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"2.", " ", "Run", " ", "the", " ", "initial", " ", "evolution"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"init", "=", 
     RowBox[{"CenterArray", "[", 
      RowBox[{
       RowBox[{"{", "1", "}"}], ",", "201"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"evolution1", "=", 
     RowBox[{"CellularAutomaton", "[", 
      RowBox[{"rule", ",", "init", ",", "steps1"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"latestState", "=", 
     RowBox[{"Last", "[", "evolution1", "]"}]}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Mix", " ", "up", " ", "the", " ", "latest", " ", "cells"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "We", " ", "replace", " ", "a", " ", "central", " ", "block", " ", "with",
      " ", "random", " ", "0", "s", " ", "and", " ", "1", "s"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mid", "=", 
     RowBox[{"IntegerPart", "[", 
      RowBox[{
       RowBox[{"Length", "[", "latestState", "]"}], "/", "2"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"perturbedState", "=", "latestState"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"perturbedState", "\[LeftDoubleBracket]", 
      RowBox[{
       RowBox[{"mid", "-", "perturbWidth"}], ";;", 
       RowBox[{"mid", "+", "perturbWidth"}]}], "\[RightDoubleBracket]"}], "=", 
     RowBox[{"RandomInteger", "[", 
      RowBox[{"1", ",", 
       RowBox[{
        RowBox[{"2", "*", "perturbWidth"}], "+", "1"}]}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Run", " ", "the", " ", "recovery", " ", "evolution"}],
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"evolution2", "=", 
     RowBox[{"CellularAutomaton", "[", 
      RowBox[{"rule", ",", "perturbedState", ",", "steps2"}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{"(*", 
    RowBox[{"5.", " ", "Visualize", " ", "the", " ", "result"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ArrayPlot", "[", 
    RowBox[{
     RowBox[{"Join", "[", 
      RowBox[{"evolution1", ",", "evolution2"}], "]"}], ",", 
     RowBox[{"Mesh", "\[Rule]", "True"}], ",", 
     RowBox[{"ColorRules", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"0", "\[Rule]", "White"}], ",", 
        RowBox[{"1", "\[Rule]", "Black"}]}], "}"}]}], ",", 
     RowBox[{"Epilog", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"Thickness", "[", "0.005", "]"}], ",", 
        RowBox[{"Line", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", 
             RowBox[{"steps2", "+", "steps1", "-", "steps1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"201", ",", 
             RowBox[{"steps2", "+", "steps1", "-", "steps1"}]}], "}"}]}], 
          "}"}], "]"}]}], "}"}]}], ",", 
     RowBox[{
     "PlotLabel", 
      "\[Rule]", "\"\<Pattern Restoration Experiment (Red Line = Mixing \
Point)\>\""}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.977905710940732*^9, 3.977905710943338*^9}},
 CellLabel->
  "In[122]:=",ExpressionUUID->"ba4ce295-9033-487b-8c51-a964e02a5e99"],

