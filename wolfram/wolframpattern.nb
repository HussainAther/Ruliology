Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "Parameters", "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"rule", "=", "110"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gridSize", "=", "301"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"steps", "=", "300"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"injuryWidth", "=", "10"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tHorizons", "=", 
     RowBox[{"{", 
      RowBox[{"5", ",", "20", ",", "50", ",", "100", ",", "150"}], "}"}]}], 
    ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Testing", " ", "different", " ", "T", " ", "values"}], "*)"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Reuse", " ", "the", " ", "CalculateResilience", " ", "logic", " ", "but",
      " ", "make", " ", "T", " ", "a", " ", "variable"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"testTIndependence", "[", 
      RowBox[{"rule_", ",", "t_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "init", ",", "clean", ",", "injured", ",", "diff", ",", "score"}], 
        "}"}], ",", 
       RowBox[{
        RowBox[{"init", "=", 
         RowBox[{"CenterArray", "[", 
          RowBox[{"1", ",", "gridSize"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"clean", "=", 
         RowBox[{"CellularAutomaton", "[", 
          RowBox[{"rule", ",", "init", ",", "steps"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Apply", " ", "disruption", " ", "at", " ", "time", " ", "T"}], 
         "*)"}], 
        RowBox[{"mid", "=", 
         RowBox[{"clean", "[", 
          RowBox[{"[", 
           RowBox[{"t", "+", "1"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"mid", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{
             RowBox[{"Floor", "[", 
              RowBox[{"gridSize", "/", "2"}], "]"}], "-", "injuryWidth"}], ";;", 
            RowBox[{
             RowBox[{"Floor", "[", 
              RowBox[{"gridSize", "/", "2"}], "]"}], "+", "injuryWidth"}]}], 
           "]"}], "]"}], "=", 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"1", ",", 
           RowBox[{
            RowBox[{"2", "*", "injuryWidth"}], "+", "1"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Evolve", " ", "injured", " ", "state", " ", "for", " ", "the", " ", 
          "remaining", " ", "steps"}], "*)"}], 
        RowBox[{"post", "=", 
         RowBox[{"CellularAutomaton", "[", 
          RowBox[{"rule", ",", "mid", ",", 
           RowBox[{"steps", "-", "t"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"injured", "=", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"Take", "[", 
            RowBox[{"clean", ",", "t"}], "]"}], ",", "post"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Difference", " ", "Map", " ", "and", " ", "Score"}], "*)"}], 
        RowBox[{"diff", "=", 
         RowBox[{"MapThread", "[", 
          RowBox[{"BitXor", ",", 
           RowBox[{"{", 
            RowBox[{"clean", ",", "injured"}], "}"}], ",", "2"}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"score", "=", 
         RowBox[{"1.0", "-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Total", "[", 
             RowBox[{"Last", "[", "diff", "]"}], "]"}], "/", "gridSize"}], 
           ")"}]}]}], ";", "\[IndentingNewLine]", "score"}]}], "]"}]}], ";"}],
    "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Run", " ", "Sampling"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tData", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t", ",", 
         RowBox[{"Mean", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"testTIndependence", "[", 
             RowBox[{"rule", ",", "t"}], "]"}], ",", 
            RowBox[{"{", "10", "}"}]}], "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "tHorizons"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Visualize", " ", "results"}], "*)"}], "\n", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{"tData", ",", 
     RowBox[{"PlotTheme", "->", "\"\<Scientific\>\""}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<T (Perturbation Horizon)\>\"", 
        ",", "\"\<Restoration Score (R)\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", 
      RowBox[{"Style", "[", 
       RowBox[{
        RowBox[{"\"\<Rule \>\"", "<>", 
         RowBox[{"ToString", "[", "rule", "]"}], 
         "<>", "\"\<: Resilience vs. Timing of Injury\>\""}], ",", "14", ",", 
        "Bold"}], "]"}]}], ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "160"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "1.1"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"Filling", "->", "Bottom"}], ",", 
     RowBox[{"ImageSize", "->", "500"}], ",", 
     RowBox[{"ImagePadding", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"60", ",", "20"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"50", ",", "20"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"(*", 
      RowBox[{
      "Adjusts", " ", "space", " ", "for", " ", "the", " ", "labels"}], 
      "*)"}], 
     RowBox[{"GridLines", "->", "Automatic"}], ",", 
     RowBox[{"InterpolationOrder", "->", "2"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.978098904605381*^9, 3.9780989046095743`*^9}, 
   3.981318482820373*^9, 3.981318514973428*^9},
 CellLabel->
  "In[197]:=",ExpressionUUID->"bb7227ae-fdfc-45e3-b677-0a0f8a035415"],

