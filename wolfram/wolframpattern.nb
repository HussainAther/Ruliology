Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Resilience", " ", "Sampling", " ", "Function"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"CalculateResilience", "[", 
      RowBox[{"rule_", ",", "width_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"steps", "=", "150"}], ",", 
         RowBox[{"mixAt", "=", "50"}], ",", "init", ",", "clean", ",", 
         "injured", ",", "diff", ",", "score"}], "}"}], ",", 
       RowBox[{
        RowBox[{"init", "=", 
         RowBox[{"CenterArray", "[", 
          RowBox[{
           RowBox[{"{", "1", "}"}], ",", "301"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"clean", "=", 
         RowBox[{"CellularAutomaton", "[", 
          RowBox[{"rule", ",", "init", ",", "steps"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Apply", " ", "disruption", " ", "at", " ", "mixAt"}], 
         "*)"}], 
        RowBox[{"injured", "=", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"pre", ",", "mid", ",", "post"}], "}"}], ",", 
           RowBox[{
            RowBox[{"pre", "=", 
             RowBox[{"Take", "[", 
              RowBox[{"clean", ",", "mixAt"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"mid", "=", 
             RowBox[{"Last", "[", "pre", "]"}]}], ";", "\[IndentingNewLine]", 
            
            RowBox[{"(*", 
             RowBox[{
             "Random", " ", "disruption", " ", "of", " ", "specified", " ", 
              "width"}], "*)"}], 
            RowBox[{
             RowBox[{"mid", "[", 
              RowBox[{"[", 
               RowBox[{
                RowBox[{"151", "-", "width"}], ";;", 
                RowBox[{"151", "+", "width"}]}], "]"}], "]"}], "=", 
             RowBox[{"RandomInteger", "[", 
              RowBox[{"1", ",", 
               RowBox[{
                RowBox[{"2", "*", "width"}], "+", "1"}]}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"post", "=", 
             RowBox[{"CellularAutomaton", "[", 
              RowBox[{"rule", ",", "mid", ",", 
               RowBox[{"steps", "-", "mixAt"}]}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"Join", "[", 
             RowBox[{"pre", ",", "post"}], "]"}]}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Difference", " ", "Map", " ", "XOR"}], "*)"}], 
        RowBox[{"diff", "=", 
         RowBox[{"MapThread", "[", 
          RowBox[{"BitXor", ",", 
           RowBox[{"{", 
            RowBox[{"clean", ",", "injured"}], "}"}], ",", "2"}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{
           RowBox[{"Score", ":", "1.0"}], "=", 
           RowBox[{"Perfect", " ", "Healing"}]}], ";", 
          RowBox[{"0.0", "=", 
           RowBox[{"Total", " ", "Failure"}]}]}], "*)"}], 
        RowBox[{"score", "=", 
         RowBox[{"1.0", "-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Total", "[", 
             RowBox[{"Last", "[", "diff", "]"}], "]"}], "/", 
            RowBox[{"Length", "[", 
             RowBox[{"Last", "[", "diff", "]"}], "]"}]}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", "score"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Sample", " ", "Rule", " ", "110", " ", "across", " ", "varying", " ", 
     "injury", " ", "widths"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"samplingData", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"w", ",", 
         RowBox[{"Mean", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"CalculateResilience", "[", 
             RowBox[{"110", ",", "w"}], "]"}], ",", 
            RowBox[{"{", "10", "}"}]}], "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"w", ",", "1", ",", "50", ",", "2"}], "}"}]}], "]"}]}], ";"}],
    "\n", "\[IndentingNewLine]", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{"samplingData", ",", 
     RowBox[{"PlotTheme", "->", "\"\<Scientific\>\""}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Injury Width\>\"", ",", "\"\<Restoration Score\>\""}], 
       "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<Rule 110: Resilience Threshold Sampling\>\"", ",", "14", ",",
         "Bold"}], "]"}]}], ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "50"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "1.1"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"Filling", "->", "Bottom"}], ",", 
     RowBox[{"ImageSize", "->", "500"}], ",", 
     RowBox[{"ImagePadding", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"60", ",", "20"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"50", ",", "20"}], "}"}]}], "}"}]}]}], " ", 
    RowBox[{"(*", 
     RowBox[{"Adds", " ", "space", " ", "for", " ", "the", " ", "text"}], 
     "*)"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.977837326800624*^9, 3.977837326802456*^9}, {
  3.981318301715578*^9, 3.981318303711603*^9}},
