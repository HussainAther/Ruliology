Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Define", " ", "Parameters"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ruleNumber", "=", "110"}], ";", 
    RowBox[{"steps", "=", "200"}], ";", 
    RowBox[{"gridSize", "=", "200"}], ";", 
    RowBox[{"noiseProb", "=", "0.02"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", 
     RowBox[{"State", ":", 
      RowBox[{"Single", " ", "Seed"}]}]}], "*)"}], 
   RowBox[{
    RowBox[{"initialState", "=", 
     RowBox[{"CenterArray", "[", 
      RowBox[{"1", ",", "gridSize"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Function", " ", "to", " ", "evolve", " ", "with", " ", "noise"}],
     "*)"}], 
   RowBox[{
    RowBox[{
     RowBox[{"evolveWithNoise", "[", 
      RowBox[{"state_", ",", "rule_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"nextState", ",", "noiseMask"}], "}"}], ",", 
       RowBox[{
        RowBox[{"nextState", "=", 
         RowBox[{
          RowBox[{"CellularAutomaton", "[", 
           RowBox[{"rule", ",", "state", ",", "1"}], "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ";", 
        RowBox[{"noiseMask", "=", 
         RowBox[{"RandomChoice", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"1", "-", "noiseProb"}], ",", "noiseProb"}], "}"}], "->", 
            RowBox[{"{", 
             RowBox[{"0", ",", "1"}], "}"}]}], ",", "gridSize"}], "]"}]}], ";", 
        RowBox[{"BitXor", "[", 
         RowBox[{"nextState", ",", "noiseMask"}], "]"}]}]}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Run", " ", "the", " ", "simulation"}], "*)"}], 
   RowBox[{
    RowBox[{"stochasticEvolution", "=", 
     RowBox[{"NestList", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"evolveWithNoise", "[", 
         RowBox[{"#", ",", "ruleNumber"}], "]"}], "&"}], ",", "initialState", 
       ",", "steps"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Visualize", " ", "Results"}], "*)"}], 
   RowBox[{"ArrayPlot", "[", 
    RowBox[{"stochasticEvolution", ",", 
     RowBox[{"ColorRules", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"0", "->", "White"}], ",", 
        RowBox[{"1", "->", "Black"}]}], "}"}]}], ",", 
     RowBox[{"Mesh", "->", "False"}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Cell Index\>\"", ",", "\"\<Time Step\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", 
      RowBox[{"\"\<Rule \>\"", "<>", 
       RowBox[{"ToString", "[", "ruleNumber", "]"}], "<>", "\"\< with \>\"", "<>", 
       RowBox[{"ToString", "[", 
        RowBox[{"noiseProb", "*", "100"}], "]"}], 
       "<>", "\"\<% Continuous Noise\>\""}]}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.97801807809778*^9, 3.978018078100226*^9}, 
   3.978018394619821*^9},
 CellLabel->
  "In[176]:=",ExpressionUUID->"b6554222-1cfd-45bf-9397-620b14dfcf33"],

