Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Setup", " ", "Directories"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"exportFolder", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
       "$HomeDirectory", ",", "\"\<Desktop\>\"", 
        ",", "\"\<Individual_Rule_Panels\>\""}], "}"}], "]"}]}], ";"}], "\n", 
   
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"!", 
       RowBox[{"FileExistsQ", "[", "exportFolder", "]"}]}], ",", 
      RowBox[{"CreateDirectory", "[", "exportFolder", "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"2.", " ", "Parameters"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"stepsBefore", "=", "100"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"stepsAfter", "=", "50"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"width", "=", "201"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"perturbWidth", "=", "10"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"3.", " ", "Generation", " ", "and", " ", "Export", " ", "Loop"}],
     "*)"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "init", ",", "clean", ",", "midState", ",", "perturbedState", ",", 
          "mixed", ",", "diff", ",", "plot", ",", "fileName"}], "}"}], ",", 
        RowBox[{"(*", 
         RowBox[{"Generate", " ", "original", " ", "CA", " ", "evolution"}], 
         "*)"}], 
        RowBox[{
         RowBox[{"init", "=", 
          RowBox[{"CenterArray", "[", 
           RowBox[{
            RowBox[{"{", "1", "}"}], ",", "width"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"clean", "=", 
          RowBox[{"CellularAutomaton", "[", 
           RowBox[{"rule", ",", "init", ",", 
            RowBox[{"stepsBefore", "+", "stepsAfter"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "Capture", " ", "state", " ", "at", " ", "the", " ", "perturbation",
            " ", "point"}], "*)"}], 
         RowBox[{"midState", "=", 
          RowBox[{"clean", "[", 
           RowBox[{"[", 
            RowBox[{"stepsBefore", "+", "1"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "Create", " ", "perturbed", " ", "state", " ", "by", " ", 
           "flipping", " ", "bits", " ", "in", " ", "the", " ", "center"}], 
          "*)"}], 
         RowBox[{"perturbedState", "=", 
          RowBox[{"ReplacePart", "[", 
           RowBox[{"midState", ",", 
            RowBox[{"Thread", "[", 
             RowBox[{
              RowBox[{"Range", "[", 
               RowBox[{
                RowBox[{"101", "-", "perturbWidth"}], ",", 
                RowBox[{"101", "+", "perturbWidth"}]}], "]"}], "->", 
              RowBox[{"RandomInteger", "[", 
               RowBox[{"1", ",", 
                RowBox[{
                 RowBox[{"2", " ", "perturbWidth"}], "+", "1"}]}], "]"}]}], 
             "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "Generate", " ", "evolution", " ", "from", " ", "the", " ", 
           "perturbed", " ", "state"}], "*)"}], 
         RowBox[{"mixed", "=", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"Take", "[", 
             RowBox[{"clean", ",", "stepsBefore"}], "]"}], ",", 
            RowBox[{"CellularAutomaton", "[", 
             RowBox[{"rule", ",", "perturbedState", ",", "stepsAfter"}], 
             "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Calculate", " ", "the", " ", "Difference", " ", "Map", " ", 
           RowBox[{"(", "XOR", ")"}], " ", "to", " ", "isolate", " ", "the", " ",
            "error", " ", "cone"}], "*)"}], 
         RowBox[{"diff", "=", 
          RowBox[{"MapThread", "[", 
           RowBox[{"BitXor", ",", 
            RowBox[{"{", 
             RowBox[{"clean", ",", "mixed"}], "}"}], ",", "2"}], "]"}]}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "Create", " ", "the", " ", "individual", " ", "plot", " ", "for", " ",
            "this", " ", "rule"}], "*)"}], 
         RowBox[{"plot", "=", 
          RowBox[{"ArrayPlot", "[", 
           RowBox[{"diff", ",", 
            RowBox[{"ColorRules", "->", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"1", "->", "Red"}], ",", 
               RowBox[{"0", "->", "White"}]}], "}"}]}], ",", 
            RowBox[{"Frame", "->", "True"}], ",", 
            RowBox[{"FrameTicks", "->", "None"}], ",", 
            RowBox[{"ImageSize", "->", "400"}], ",", 
            RowBox[{"PlotLabel", "->", 
             RowBox[{"Style", "[", 
              RowBox[{
               RowBox[{"\"\<Rule \>\"", "<>", 
                RowBox[{"ToString", "[", "rule", "]"}]}], ",", "14", ",", 
               "Bold"}], "]"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "Export", " ", "as", " ", "a", " ", "singular", " ", "PNG", " ", 
           "for", " ", "this", " ", "specific", " ", "rule"}], "*)"}], 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"IntegerString", " ", "with", " ", "10"}], ",", 
           RowBox[{
           "3", " ", "ensures", " ", "files", " ", "are", " ", "named", " ", 
            "Rule_", "000.", "png"}], ",", 
           RowBox[{"Rule_", "001.", "png"}], ",", 
           RowBox[{"etc", "."}]}], "*)"}], 
         RowBox[{"fileName", "=", 
          RowBox[{"FileNameJoin", "[", 
           RowBox[{"{", 
            RowBox[{"exportFolder", ",", 
             RowBox[{"\"\<Rule_\>\"", "<>", 
              RowBox[{"IntegerString", "[", 
               RowBox[{"rule", ",", "10", ",", "3"}], "]"}], 
              "<>", "\"\<.png\>\""}]}], "}"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Export", "[", 
          RowBox[{"fileName", ",", "plot", ",", "\"\<PNG\>\""}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Progress", " ", "tracking"}], "*)"}], 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{"rule", ",", "32"}], "]"}], "==", "0"}], ",", 
           RowBox[{"Print", "[", 
            RowBox[{"\"\<Processing Rule: \>\"", ",", "rule"}], "]"}]}], 
          "]"}], ";"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"rule", ",", "0", ",", "255"}], "}"}]}], "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Done! 256 individual panels have been saved to the \
'Individual_Rule_Panels' folder on your Desktop.\>\"", "]"}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9780943621974707`*^9, 3.978094362199728*^9}, {
   3.97809550206044*^9, 3.9780955027153378`*^9}, 3.9780957219990883`*^9},
 CellLabel->
  "In[189]:=",ExpressionUUID->"0a16be41-8f3e-407b-8654-44f1baba9b93"],

