          RowBox[{"metrics", "[", "\"\<Rfull\>\"", "]"}], ",", "density", ",",
           "entropy", ",", "variation"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Rule\>\"", "->", "rule"}], ",", 
         RowBox[{"\"\<ControlEvolution\>\"", "->", "controlEvo"}], ",", 
