    RowBox[{"runSingleTrial", "[", 
     RowBox[{"rule_Integer", ",", 
      RowBox[{"injuryMode_", ":", "\"\<RandomBinary\>\""}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "init", ",", "controlEvo", ",", "injuredState", ",", "postInjuryEvo", ",",
         "injuredFullEvo", ",", "metrics", ",", "density", ",", "entropy", ",",
         "variation", ",", "class"}], "}"}], ",", 
      RowBox[{
       RowBox[{"init", "=", 
        RowBox[{"makeInitialState", "[", "width", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"controlEvo", "=", 
        RowBox[{"CellularAutomaton", "[", 
         RowBox[{"rule", ",", "init", ",", "steps"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
