 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"renderShellLike", "[", 
     RowBox[{"evo_", ",", 
      RowBox[{"title_", ":", "\"\<Shell-like rendering\>\""}]}], "]"}], ":=", 
    
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"arr", ",", "nRows", ",", "nCols", ",", "pts", ",", "cells"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"arr", "=", 
        RowBox[{"Reverse", "[", "evo", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"nRows", ",", "nCols"}], "}"}], "=", 
        RowBox[{"Dimensions", "[", "arr", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"pts", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"j", "-", 
               RowBox[{"nCols", "/", "2"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"nCols", "/", "2"}], ")"}]}], ",", 
            RowBox[{"i", "/", "nRows"}], ",", 
            RowBox[{
             RowBox[{"0.25", "*", 
              RowBox[{"(", 
               RowBox[{"1", "-", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"j", "-", 
                    RowBox[{"nCols", "/", "2"}]}], ")"}], "/", 
                   RowBox[{"(", 
                    RowBox[{"nCols", "/", "2"}], ")"}]}], ")"}], "^", "2"}]}],
                ")"}]}], "+", 
             RowBox[{"0.05", "*", 
              RowBox[{"arr", "[", 
               RowBox[{"[", 
                RowBox[{"i", ",", "j"}], "]"}], "]"}]}]}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "nRows"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "nCols"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"cells", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"arr", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", "j"}], "]"}], "]"}], "==", "1"}], ",", 
              "Black", ",", "White"}], "]"}], ",", 
            RowBox[{"Polygon", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"pts", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", "j"}], "]"}], "]"}], ",", 
               RowBox[{"pts", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"i", "+", "1"}], ",", "j"}], "]"}], "]"}], ",", 
               RowBox[{"pts", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"i", "+", "1"}], ",", 
                  RowBox[{"j", "+", "1"}]}], "]"}], "]"}], ",", 
               RowBox[{"pts", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", 
                  RowBox[{"j", "+", "1"}]}], "]"}], "]"}]}], "}"}], "]"}]}], 
           "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"nRows", "-", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", 
            RowBox[{"nCols", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Graphics3D", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", "cells", "]"}], ",", 
         RowBox[{"Boxed", "->", "False"}], ",", 
         RowBox[{"Lighting", "->", "\"\<Neutral\>\""}], ",", 
         RowBox[{"ViewPoint", "->", 
          RowBox[{"{", 
