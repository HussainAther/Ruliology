 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"injureState", "[", 
     RowBox[{"state_List", ",", "radius_Integer", ",", 
      RowBox[{"mode_", ":", "\"\<RandomBinary\>\""}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"center", ",", "injuryPositions", ",", "replacementValues"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"center", "=", 
        RowBox[{"Ceiling", "[", 
         RowBox[{
          RowBox[{"Length", "[", "state", "]"}], "/", "2"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"injuryPositions", "=", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{"Range", "[", 
           RowBox[{
            RowBox[{"center", "-", "radius"}], ",", 
            RowBox[{"center", "+", "radius"}]}], "]"}], ",", 
          RowBox[{
           RowBox[{"1", "<=", "#", "<=", 
            RowBox[{"Length", "[", "state", "]"}]}], "&"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"replacementValues", "=", 
        RowBox[{"Switch", "[", 
         RowBox[{"mode", ",", "\"\<RandomBinary\>\"", ",", 
          RowBox[{"RandomInteger", "[", 
           RowBox[{"1", ",", 
            RowBox[{"Length", "[", "injuryPositions", "]"}]}], "]"}], 
          ",", "\"\<Delete\>\"", ",", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0", ",", 
            RowBox[{"Length", "[", "injuryPositions", "]"}]}], "]"}], 
          ",", "\"\<Flip\>\"", ",", 
          RowBox[{"1", "-", 
           RowBox[{"state", "[", 
            RowBox[{"[", "injuryPositions", "]"}], "]"}]}], ",", "_", ",", 
          RowBox[{"RandomInteger", "[", 
           RowBox[{"1", ",", 
            RowBox[{"Length", "[", "injuryPositions", "]"}]}], "]"}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ReplacePart", "[", 
        RowBox[{"state", ",", 
         RowBox[{"Thread", "[", 
          RowBox[{"injuryPositions", "->", "replacementValues"}], "]"}]}], 
        "]"}]}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
