       "\[IndentingNewLine]", 
       RowBox[{"postInjuryEvo", "=", 
        RowBox[{"CellularAutomaton", "[", 
         RowBox[{"rule", ",", "injuredState", ",", 
          RowBox[{"steps", "-", "injuryStep"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"injuredFullEvo", "=", 
