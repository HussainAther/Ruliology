       "\[IndentingNewLine]", 
       RowBox[{"entropy", "=", 
        RowBox[{"meanEntropy", "[", "controlEvo", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"variation", "=", 
        RowBox[{"adjacencyVariation", "[", "controlEvo", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"class", "=", 
