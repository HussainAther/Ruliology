 RowBox[{
  RowBox[{
   RowBox[{"panel1", "=", 
    RowBox[{"ArrayPlot", "[", 
     RowBox[{"controlEvo", ",", 
      RowBox[{"ColorRules", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"0", "->", "White"}], ",", 
