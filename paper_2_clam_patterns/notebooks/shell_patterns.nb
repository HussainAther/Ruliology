      RowBox[{"ImageSize", "->", "300"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"panel3", "=", 
    RowBox[{"ArrayPlot", "[", 
     RowBox[{
      RowBox[{"{", "xorFinal", "}"}], ",", 
      RowBox[{"ColorRules", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"0", "->", "White"}], ",", 
