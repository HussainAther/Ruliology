      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"Mesh", "->", "False"}], ",", 
      RowBox[{"PlotLabel", "->", 
       RowBox[{"Style", "[", 
        RowBox[{"\"\<A. Control Conus-like growth\>\"", ",", "13", ",", 
         "Bold"}], "]"}]}], ",", 
      RowBox[{"ImageSize", "->", "300"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
