Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", "===", "===", "===", "===", "===", "===", "==="}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"1.", " ", "Parameters"}], "===", "===", "===", "===", "===", "===",
       "===", "==="}], "="}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rule", "=", "30"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"width", "=", "201"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"steps", "=", "150"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"injuryStep", "=", "40"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"injuryRadius", "=", "8"}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", "===", "===", "===", "===", "===", "===", "==="}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
      "2.", " ", "Initial", " ", "1", "D", " ", "mantle", " ", "state"}], "===",
       "===", "===", "===", "===", "===", "===", "==="}], "="}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"init", "=", 
   RowBox[{"ConstantArray", "[", 
    RowBox[{"0", ",", "width"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"init", "[", 
     RowBox[{"[", 
      RowBox[{"Ceiling", "[", 
       RowBox[{"width", "/", "2"}], "]"}], "]"}], "]"}], "=", "1"}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", "===", "===", "===", "===", "===", "===", "==="}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"3.", " ", "Control", " ", "evolution"}], "===", "===", "===", "===",
       "===", "===", "===", "==="}], "="}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"controlEvo", "=", 
    RowBox[{"CellularAutomaton", "[", 
     RowBox[{"rule", ",", "init", ",", "steps"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", "===", "===", "===", "===", "===", "===", "==="}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
      "4.", " ", "Injure", " ", "one", " ", "intermediate", " ", "row"}], "===",
       "===", "===", "===", "===", "===", "===", "==="}], "="}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"injuredState", "=", 
    RowBox[{"controlEvo", "[", 
     RowBox[{"[", 
      RowBox[{"injuryStep", "+", "1"}], "]"}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"center", "=", 
   RowBox[{"Ceiling", "[", 
    RowBox[{"width", "/", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"injuryPositions", "=", 
    RowBox[{"Range", "[", 
     RowBox[{
      RowBox[{"center", "-", "injuryRadius"}], ",", 
      RowBox[{"center", "+", "injuryRadius"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"injuredState2", "=", 
    RowBox[{"ReplacePart", "[", 
     RowBox[{"injuredState", ",", 
      RowBox[{"Thread", "[", 
       RowBox[{"injuryPositions", "->", 
        RowBox[{"RandomInteger", "[", 
         RowBox[{"1", ",", 
          RowBox[{"Length", "[", "injuryPositions", "]"}]}], "]"}]}], "]"}]}],
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", "===", "===", "===", "===", "===", "===", "==="}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
      "5.", " ", "Continue", " ", "evolution", " ", "after", " ", "injury"}], 
      "===", "===", "===", "===", "===", "===", "===", "==="}], "="}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"postInjuryEvo", "=", 
    RowBox[{"CellularAutomaton", "[", 
     RowBox[{"rule", ",", "injuredState2", ",", 
      RowBox[{"steps", "-", "injuryStep"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"injuredFullEvo", "=", 
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"controlEvo", "[", 
       RowBox[{"[", 
        RowBox[{"1", ";;", "injuryStep"}], "]"}], "]"}], ",", 
      "postInjuryEvo"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", "===", "===", "===", "===", "===", "===", "==="}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
      "6.", " ", "Difference", " ", "map", " ", "and", " ", "restoration", " ",
        "coefficient"}], "===", "===", "===", "===", "===", "===", "===", 
      "==="}], "="}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"finalControl", "=", 
   RowBox[{"controlEvo", "[", 
    RowBox[{"[", 
     RowBox[{"-", "1"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"finalInjured", "=", 
    RowBox[{"injuredFullEvo", "[", 
     RowBox[{"[", 
      RowBox[{"-", "1"}], "]"}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"xorFinal", "=", 
    RowBox[{"Mod", "[", 
     RowBox[{
      RowBox[{"finalControl", "+", "finalInjured"}], ",", "2"}], "]"}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"R", "=", 
    RowBox[{"1", "-", 
     RowBox[{"N", "[", 
      RowBox[{
       RowBox[{"Total", "[", "xorFinal", "]"}], "/", 
       RowBox[{"Length", "[", "xorFinal", "]"}]}], "]"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Restoration Coefficient R = \>\"", ",", "R"}], "]"}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", "===", "===", "===", "===", "===", "===", "==="}], "=", 
