 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"makeInitialState", "[", "w_Integer", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "init", "}"}], ",", 
      RowBox[{
       RowBox[{"init", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", "w"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"init", "[", 
         RowBox[{"[", 
          RowBox[{"Ceiling", "[", 
           RowBox[{"w", "/", "2"}], "]"}], "]"}], "]"}], "=", "1"}], ";", 
       "\[IndentingNewLine]", "init"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"injureState", "[", 
     RowBox[{"state_List", ",", "radius_Integer"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"center", ",", "injuryPositions", ",", "replacementValues"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"center", "=", 
        RowBox[{"Ceiling", "[", 
         RowBox[{
          RowBox[{"Length", "[", "state", "]"}], "/", "2"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"injuryPositions", "=", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{"Range", "[", 
           RowBox[{
            RowBox[{"center", "-", "radius"}], ",", 
            RowBox[{"center", "+", "radius"}]}], "]"}], ",", 
          RowBox[{
           RowBox[{"1", "<=", "#", "<=", 
            RowBox[{"Length", "[", "state", "]"}]}], "&"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"replacementValues", "=", 
        RowBox[{"RandomInteger", "[", 
         RowBox[{"1", ",", 
          RowBox[{"Length", "[", "injuryPositions", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ReplacePart", "[", 
        RowBox[{"state", ",", 
         RowBox[{"Thread", "[", 
          RowBox[{"injuryPositions", "->", "replacementValues"}], "]"}]}], 
        "]"}]}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"restorationMetrics", "[", 
     RowBox[{"controlEvo_", ",", "injuredFullEvo_", ",", "injStep_Integer"}], 
     "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "finalControl", ",", "finalInjured", ",", "xorFinal", ",", "Rfinal", ",",
         "controlPost", ",", "injuredPost", ",", "xorPost", ",", "Rfull"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"finalControl", "=", 
        RowBox[{"controlEvo", "[", 
         RowBox[{"[", 
          RowBox[{"-", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"finalInjured", "=", 
        RowBox[{"injuredFullEvo", "[", 
         RowBox[{"[", 
          RowBox[{"-", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"xorFinal", "=", 
        RowBox[{"Mod", "[", 
         RowBox[{
          RowBox[{"finalControl", "+", "finalInjured"}], ",", "2"}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"Rfinal", "=", 
        RowBox[{"1", "-", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"Total", "[", "xorFinal", "]"}], "/", 
           RowBox[{"Length", "[", "xorFinal", "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"controlPost", "=", 
        RowBox[{"controlEvo", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"injStep", "+", "1"}], ";;"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"injuredPost", "=", 
        RowBox[{"injuredFullEvo", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"injStep", "+", "1"}], ";;"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"xorPost", "=", 
        RowBox[{"Mod", "[", 
         RowBox[{
          RowBox[{"controlPost", "+", "injuredPost"}], ",", "2"}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"Rfull", "=", 
        RowBox[{"1", "-", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"Total", "[", 
            RowBox[{"Flatten", "[", "xorPost", "]"}], "]"}], "/", 
           RowBox[{"Length", "[", 
            RowBox[{"Flatten", "[", "xorPost", "]"}], "]"}]}], "]"}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<FinalXOR\>\"", "->", "xorFinal"}], ",", 
         RowBox[{"\"\<PostXOR\>\"", "->", "xorPost"}], ",", 
         RowBox[{"\"\<Rfinal\>\"", "->", "Rfinal"}], ",", 
         RowBox[{"\"\<Rfull\>\"", "->", "Rfull"}]}], "|>"}]}]}], "]"}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
