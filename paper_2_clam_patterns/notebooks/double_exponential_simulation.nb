      "}"}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pngResult", "=", 
   RowBox[{"Export", "[", 
    RowBox[{"pngPath", ",", "finalFigure", ",", 
     RowBox[{"ImageResolution", "->", "300"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
