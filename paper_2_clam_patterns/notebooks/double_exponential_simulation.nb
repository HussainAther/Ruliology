Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"finalFigure", "=", 
    RowBox[{"GraphicsRow", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"panelA", ",", "panelB"}], "}"}], ",", 
      RowBox[{"Spacings", "->", "25"}], ",", 
      RowBox[{"Background", "->", "White"}], ",", 
      RowBox[{"ImageSize", "->", "1150"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"finalFigure", "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"exportDir", "=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Head", "[", 
        RowBox[{"NotebookDirectory", "[", "]"}], "]"}], "===", "String"}], ",", 
      RowBox[{"NotebookDirectory", "[", "]"}], ",", 
      RowBox[{"Directory", "[", "]"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pngPath", "=", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{"exportDir", ",", "\"\<complexity_gap_two_panel.png\>\""}], 
     "}"}], "]"}]}], ";"}], "\n", 
